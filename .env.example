# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong unique value, e.g.  openssl rand -hex 32
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d
JWT_AGENT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100

# ── Heartbeat / Rounds ────────────────────────────────────────────────────────
HEARTBEAT_TIMEOUT_SECONDS=90
HEARTBEAT_INTERVAL_SECONDS=30
CHECKPOINT_INTERVAL=10
ROUND_TIMEOUT_SECONDS=120
DISCONNECT_GRACE_SECONDS=15

# ── Public URL (injected into downloaded agent scripts) ───────────────────────
# BACKEND_URL=https://your-backend.example.com

# ── Socket.IO tuning (optional) ───────────────────────────────────────────────
# SOCKET_IO_MAX_HTTP_BUFFER_MB=50
# SOCKET_IO_WEBSOCKET_ONLY=true
# SOCKET_IO_PING_TIMEOUT_MS=60000
# SOCKET_IO_PING_INTERVAL_MS=25000
